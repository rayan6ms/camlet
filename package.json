{
	"name": "camlet",
	"version": "0.1.0",
	"description": "Lightweight Electron webcam overlay foundation for Linux-first desktops.",
	"private": true,
	"author": "Camlet contributors",
	"license": "GPL-3.0-only",
	"type": "module",
	"packageManager": "pnpm@9.0.0",
	"main": "dist-electron/main/index.js",
	"productName": "Camlet",
	"scripts": {
		"clean": "node ./scripts/clean.mjs",
		"dev": "node ./scripts/dev.mjs",
		"dev:renderer": "vite --config vite.config.ts",
		"dev:electron": "node ./scripts/dev.mjs --electron-only",
		"build": "pnpm clean && pnpm build:electron && pnpm build:renderer",
		"build:electron": "tsc -p tsconfig.electron.json",
		"build:renderer": "vite build --config vite.config.ts",
		"typecheck": "tsc -b --pretty false",
		"test": "vitest run",
		"test:unit": "vitest run tests/unit",
		"test:integration": "vitest run tests/integration",
		"verify": "pnpm typecheck && pnpm check && pnpm test && pnpm build",
		"package": "pnpm build && electron-builder --config electron-builder.yml --publish never",
		"package:linux": "pnpm build && electron-builder --config electron-builder.yml --linux AppImage --publish never",
		"package:win": "pnpm build && electron-builder --config electron-builder.yml --win nsis --publish never",
		"dist": "pnpm package",
		"check": "biome check .",
		"format": "biome format --write ."
	},
	"dependencies": {
		"electron-store": "^11.0.2",
		"i18next": "^26.0.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@playwright/test": "^1.59.1",
		"@types/node": "^25.5.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"electron": "^41.1.1",
		"electron-builder": "^26.8.1",
		"playwright": "^1.59.1",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.3"
	}
}
