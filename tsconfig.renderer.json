{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"composite": true,
		"tsBuildInfoFile": ".tsbuildinfo/renderer.tsbuildinfo",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"noEmit": true,
		"types": ["vite/client"]
	},
	"include": ["src/renderer/**/*.ts", "src/shared/**/*.ts"]
}
