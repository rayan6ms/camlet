{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"composite": true,
		"tsBuildInfoFile": ".tsbuildinfo/renderer.tsbuildinfo",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"jsx": "react-jsx",
		"noEmit": true,
		"types": ["vite/client"]
	},
	"include": [
		"src/renderer/**/*.ts",
		"src/renderer/**/*.tsx",
		"src/shared/**/*.ts"
	]
}
